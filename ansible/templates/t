
server {
    listen 80 default_server;
    server_name edgepaas.duckdns.org;

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2 default_server;
    server_name edgepaas.duckdns.org;

    ssl_certificate /etc/letsencrypt/live/edgepaas.duckdns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/edgepaas.duckdns.org/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers "HIGH:!aNULL:!MD5";
